```{=html}
<%
// Helper function to safely escape HTML attributes
function escapeHtml(text) {
  if (!text) return '';
  return text.toString()
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#x27;');
}
%>
<div class="teaching">
  <% if (items && items.length > 0) { %>
    <% for (const course of items) { %>
      <div class="course-entry">
        <div class="body">
          <p class="course-title"><%= escapeHtml(course.title) %></p>
          <p class="course-details">
            <% if (course.number) { %>
              <span class="course-number"><%= escapeHtml(course.number) %></span> |
            <% } %>
            <span class="course-university"><%= escapeHtml(course.university) %></span>
            <% if (course.role) { %>
              | <span class="course-role"><%= escapeHtml(course.role) %></span>
            <% } %>
          </p>
          <% if (course.description) { %>
            <details class="course-description">
              <summary>Course description</summary>
              <p><%= escapeHtml(course.description) %></p>
            </details>
          <% } %>
          <div class="course-meta">
            <% if (course.semesters && course.semesters.length > 0) { %>
              <ul class="course-semesters">
                <% for (const semester of course.semesters) { %>
                  <li><%= escapeHtml(semester.name) %></li>
                <% } %>
              </ul>
            <% } %>
            <% if (course.links && course.links.length > 0) { %>
              <ul class="course-links">
                <% for (const link of course.links) { %>
                  <li>
                    <a href="<%= escapeHtml(link.url) %>" target="_blank" rel="noopener noreferrer">
                      <i class="<%= escapeHtml(link.icon) %>"></i> <%= escapeHtml(link.name) %>
                    </a>
                  </li>
                <% } %>
              </ul>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>
  <% } else { %>
    <div class="no-courses">
      <p>No courses available at this time.</p>
    </div>
  <% } %>
</div>
```